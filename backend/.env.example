ANTHROPIC_API_KEY=sk-ant-...

# GitHub OAuth (create app at https://github.com/settings/developers)
#   Homepage URL:            http://localhost:3000
#   Authorization callback:  http://localhost:8000/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/auth/github/callback

# Where the frontend lives — used for CORS and post-auth redirect.
# Comma-separated if you need multiple origins (e.g. localhost + prod).
FRONTEND_URL=http://localhost:3000

# Set to "true" in production (HTTPS). Keep "false" for local dev.
COOKIE_SECURE=false
